# Demo mode — works with zero external services (recommended for publish/deploy)
DEMO_MODE=true

# ClickHouse (production only)
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=startup_scout

# Agents
DISCOVERY_INTERVAL_MINUTES=15
SCORE_THRESHOLD=85

# AI (optional — Claude via Anthropic; heuristic fallback without key)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Composio automation (optional — mock mode without key)
COMPOSIO_API_KEY=
COMPOSIO_SLACK_ACCOUNT_ID=
SLACK_CHANNEL=#startup-scout

# GitHub (optional)
GITHUB_TOKEN=
GITHUB_REPO=your-org/startup-reviews
