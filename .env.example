# Set to true for demo mode (no external services needed)
# Set to false to use live data with Neon + Gemini + GitHub
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false

# Neon PostgreSQL (free at neon.tech — get your connection string from the dashboard)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Google Gemini (free at aistudio.google.com — 1M tokens/day, no credit card)
GEMINI_API_KEY=your-gemini-api-key

# GitHub Personal Access Token (free — raises rate limit from 60 to 5000 req/hr)
# Get at: github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Optional: Anthropic Claude (paid — Gemini is used if not set)
ANTHROPIC_API_KEY=

# Optional: Composio for Slack/Gmail/Notion notifications
COMPOSIO_API_KEY=
COMPOSIO_SLACK_ACCOUNT_ID=
SLACK_CHANNEL=#startup-scout

# Optional: GitHub issue notifications
GITHUB_REPO=your-org/startup-reviews

# Agent settings
DISCOVERY_INTERVAL_MINUTES=15
SCORE_THRESHOLD=85
