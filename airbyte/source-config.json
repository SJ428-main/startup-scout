{
  "name": "startup-scout-sources",
  "description": "Airbyte source connectors for Startup Scout AI data ingestion",
  "sources": [
    {
      "name": "github-trending",
      "connector": "source-github",
      "config": {
        "repository": "trending",
        "start_date": "2024-01-01",
        "credentials": {
          "option_title": "OAuth Credentials",
          "access_token": "${GITHUB_TOKEN}"
        }
      },
      "streams": ["repositories", "commits", "stargazers"]
    },
    {
      "name": "hacker-news",
      "connector": "source-hackernews",
      "config": {
        "start_date": "2024-01-01",
        "item_id": "top"
      },
      "streams": ["items", "users"]
    },
    {
      "name": "rss-feeds",
      "connector": "source-rss",
      "config": {
        "feeds": [
          "https://blog.langchain.dev/rss/",
          "https://openai.com/blog/rss.xml",
          "https://www.anthropic.com/feed.xml"
        ]
      },
      "streams": ["articles"]
    }
  ],
  "destination": {
    "name": "clickhouse-startup-scout",
    "connector": "destination-clickhouse",
    "config": {
      "host": "${CLICKHOUSE_HOST}",
      "port": 8123,
      "database": "startup_scout",
      "username": "${CLICKHOUSE_USER}",
      "password": "${CLICKHOUSE_PASSWORD}",
      "tables": {
        "companies": "companies",
        "articles": "articles",
        "sources": "sources"
      }
    }
  },
  "sync_schedule": "*/15 * * * *"
}
